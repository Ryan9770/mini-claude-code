# 이 파일을 .env로 복사해서 값을 채우세요 (cp .env.example .env).
# .env는 gitignore되어 커밋되지 않습니다. 실제 비밀은 .env에만.

# ── 로컬 추론 서버 (선택 — 미설정 시 config 기본값) ──
# MCC_BASE_URL=http://10.1.10.111:8080/v1
# MCC_CONTEXT_SIZE=32768

# ── 2티어 검증: 클라우드 리뷰어 (선택) ──
# 생성은 로컬 모델, critic의 '리뷰'만 강한 클라우드 모델에 위탁.
# provider 프리셋: gemini | openai | anthropic  (또는 MCC_REVIEW_BASE_URL로 커스텀 엔드포인트)
# 셋 다 있어야 활성화. 없으면 로컬 모델이 리뷰(기존 동작).
MCC_REVIEW_PROVIDER=gemini
MCC_REVIEW_MODEL=gemini-2.5-pro
MCC_REVIEW_API_KEY=여기에-키-입력
